"openapi: 3.0.3\ninfo:\n  title: \u0027\u0027\n  version: 0.0.0\npaths:\n  /api/v1/clients:\n    get:\n      operationId: clients_list\n      summary: Получение всех клиентов\n      parameters:\n      - name: page\n        required: false\n        in: query\n        description: A page number within the paginated result set.\n        schema:\n          type: integer\n      tags:\n      - clients\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/PaginatedClientList\u0027\n          description: \u0027\u0027\n    post:\n      operationId: clients_create\n      summary: Создание клиента\n      tags:\n      - clients\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/Client\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/Client\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/Client\u0027\n        required: true\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027201\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Client\u0027\n          description: \u0027\u0027\n  /api/v1/clients/{id}:\n    get:\n      operationId: clients_retrieve\n      summary: Получение клиента по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this client.\n        required: true\n      tags:\n      - clients\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Client\u0027\n          description: \u0027\u0027\n    patch:\n      operationId: clients_partial_update\n      summary: Частичное обновление данных клиента\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this client.\n        required: true\n      tags:\n      - clients\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedClient\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedClient\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedClient\u0027\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Client\u0027\n          description: \u0027\u0027\n    delete:\n      operationId: clients_destroy\n      summary: Удаление клиента по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this client.\n        required: true\n      tags:\n      - clients\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027204\u0027:\n          description: No response body\n  /api/v1/employees:\n    get:\n      operationId: employees_list\n      description: Возвращает всех сотрудников, с их типом зарплаты и графиком работы\n      summary: Получение всех сотрудников\n      parameters:\n      - name: page\n        required: false\n        in: query\n        description: A page number within the paginated result set.\n        schema:\n          type: integer\n      tags:\n      - employees\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/PaginatedEmployeeList\u0027\n          description: \u0027\u0027\n    post:\n      operationId: employees_create\n      summary: Создание сотрудника\n      tags:\n      - employees\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/Employee\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/Employee\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/Employee\u0027\n        required: true\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027201\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Employee\u0027\n          description: \u0027\u0027\n  /api/v1/employees/{id}:\n    get:\n      operationId: employees_retrieve\n      summary: Получение сотдруника по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this employee.\n        required: true\n      tags:\n      - employees\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Employee\u0027\n          description: \u0027\u0027\n    patch:\n      operationId: employees_partial_update\n      summary: Частичное обновление данных сотдруника\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this employee.\n        required: true\n      tags:\n      - employees\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedEmployee\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedEmployee\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedEmployee\u0027\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Employee\u0027\n          description: \u0027\u0027\n    delete:\n      operationId: employees_destroy\n      summary: Удаление сотрудника по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this employee.\n        required: true\n      tags:\n      - employees\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027204\u0027:\n          description: No response body\n  /api/v1/employees/{id}/finance-report:\n    get:\n      operationId: employees_finance_report_retrieve\n      description: \"Возвращает фин. отчет сотрудника.\\n        Формирование отчета:\n        зарплата + бонусы - штрафы = общая сумма за месяц.\\n        Возращаемый ответ:\n        общая сумма выплат по месяцам и годам.\\n        Можно указать dateFrom (optional)\n        (дата начала отчета) и dateTo (optional) (дата конца отчета). \\n        Если\n        dateFrom не указан, отчет будет сделан с даты добавления сотрудника в систему.\n        \\n        Если dateFrom не указан но указан dateTo, то отчет будет сформирован\n        с даты добавления сотрудника в систему до выбранной даты dateTo.\\n        Если\n        dateFrom и dateTo не указаны, отчет будет сформирован за все время\"\n      summary: Получение финансового отчета сотрудника по его ID\n      parameters:\n      - in: query\n        name: dateFrom\n        schema:\n          type: string\n          format: date\n        description: Start date (YYYY-MM-DD)\n      - in: query\n        name: dateTo\n        schema:\n          type: string\n          format: date\n        description: End date (YYYY-MM-DD)\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this employee.\n        required: true\n      tags:\n      - employees\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Employee\u0027\n          description: \u0027\u0027\n  /api/v1/employees/{id}/payments:\n    get:\n      operationId: employees_payments_list\n      summary: Получение всех выплат сотдрунику по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this employee.\n        required: true\n      - name: page\n        required: false\n        in: query\n        description: A page number within the paginated result set.\n        schema:\n          type: integer\n      tags:\n      - employees\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/PaginatedSalaryList\u0027\n          description: \u0027\u0027\n  /api/v1/employees/{id}/schedules:\n    get:\n      operationId: employees_schedules_list\n      summary: Получение графика работы сотрудника по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this employee.\n        required: true\n      - name: page\n        required: false\n        in: query\n        description: A page number within the paginated result set.\n        schema:\n          type: integer\n      tags:\n      - employees\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/PaginatedWorkScheduleSerializerSubList\u0027\n          description: \u0027\u0027\n  /api/v1/salary:\n    get:\n      operationId: salary_list\n      summary: Получение всех выплат всех сотрудников\n      parameters:\n      - name: page\n        required: false\n        in: query\n        description: A page number within the paginated result set.\n        schema:\n          type: integer\n      tags:\n      - salary\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/PaginatedSalaryList\u0027\n          description: \u0027\u0027\n    post:\n      operationId: salary_create\n      summary: Добавление выплаты сотруднику\n      tags:\n      - salary\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/Salary\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/Salary\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/Salary\u0027\n        required: true\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027201\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Salary\u0027\n          description: \u0027\u0027\n  /api/v1/salary/{id}:\n    get:\n      operationId: salary_retrieve\n      summary: Получение выплаты по ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this salary payment.\n        required: true\n      tags:\n      - salary\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Salary\u0027\n          description: \u0027\u0027\n    patch:\n      operationId: salary_partial_update\n      summary: Частичное обновление выплыта по ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this salary payment.\n        required: true\n      tags:\n      - salary\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedSalary\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedSalary\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedSalary\u0027\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Salary\u0027\n          description: \u0027\u0027\n    delete:\n      operationId: salary_destroy\n      summary: Удаление выплаты по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this salary payment.\n        required: true\n      tags:\n      - salary\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027204\u0027:\n          description: No response body\n  /api/v1/schedules:\n    get:\n      operationId: schedules_list\n      summary: Получение всех график работ всех сотрудников\n      parameters:\n      - name: page\n        required: false\n        in: query\n        description: A page number within the paginated result set.\n        schema:\n          type: integer\n      tags:\n      - schedules\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/PaginatedScheduleList\u0027\n          description: \u0027\u0027\n    post:\n      operationId: schedules_create\n      summary: Добавление график работы сотруднику\n      tags:\n      - schedules\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/Schedule\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/Schedule\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/Schedule\u0027\n        required: true\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027201\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Schedule\u0027\n          description: \u0027\u0027\n  /api/v1/schedules/{id}:\n    get:\n      operationId: schedules_retrieve\n      summary: Получение графика работы по ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this work schedule.\n        required: true\n      tags:\n      - schedules\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Schedule\u0027\n          description: \u0027\u0027\n    patch:\n      operationId: schedules_partial_update\n      summary: Частичное обновление графика работы по ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this work schedule.\n        required: true\n      tags:\n      - schedules\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedSchedule\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedSchedule\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedSchedule\u0027\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Schedule\u0027\n          description: \u0027\u0027\n    delete:\n      operationId: schedules_destroy\n      summary: Удаление графика работы его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this work schedule.\n        required: true\n      tags:\n      - schedules\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027204\u0027:\n          description: No response body\n  /api/v1/schema/:\n    get:\n      operationId: schema_retrieve\n      description: |-\n        OpenApi3 schema for this API. Format can be selected via content negotiation.\n\n        - YAML: application/vnd.oai.openapi\n        - JSON: application/vnd.oai.openapi+json\n      parameters:\n      - in: query\n        name: format\n        schema:\n          type: string\n          enum:\n          - json\n          - yam