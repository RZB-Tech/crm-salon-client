ly: true\n        updatedAt:\n          type: string\n          format: date-time\n          readOnly: true\n        name:\n          type: string\n          maxLength: 255\n    PaymentTypeEnum:\n      enum:\n      - salary\n      - bonus\n      - penalty\n      - percent from services\n      - percent from sefl services\n      - percent from sales\n      - percent from self sales\n      - precent from attracting client\n      - precent from developing client\n      type: string\n      description: |-\n        * `salary` - Salary\n        * `bonus` - Bonus\n        * `penalty` - Penalty\n        * `percent from services` - Prcnt Service\n        * `percent from sefl services` - Prcnt Self Service\n        * `percent from sales` - Prcnt Sales\n        * `percent from self sales` - Prcnt Self Sales\n        * `precent from attracting client` - Prcnt Attract Client\n        * `precent from developing client` - Prcnt Develop Client\n    Salary:\n      type: object\n      properties:\n        id:\n          type: integer\n          readOnly: true\n        createdAt:\n          type: string\n          format: date-time\n          readOnly: true\n        updatedAt:\n          type: string\n          format: date-time\n          readOnly: true\n        paymentType:\n          $ref: \u0027#/components/schemas/PaymentTypeEnum\u0027\n        amount:\n          type: string\n          format: decimal\n          pattern: ^-?\\d{0,8}(?:\\.\\d{0,2})?$\n        note:\n          type: string\n        employee:\n          type: integer\n      required:\n      - amount\n      - createdAt\n      - employee\n      - id\n      - paymentType\n      - updatedAt\n    SalaryPaymentsSerializerSub:\n      type: object\n      properties:\n        id:\n          type: integer\n          readOnly: true\n        createdAt:\n          type: string\n          format: date-time\n          readOnly: true\n        updatedAt:\n          type: string\n          format: date-time\n          readOnly: true