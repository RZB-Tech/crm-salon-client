  additionalProperties: {}\n            application/yaml:\n              schema:\n                type: object\n                additionalProperties: {}\n            application/vnd.oai.openapi+json:\n              schema:\n                type: object\n                additionalProperties: {}\n            application/json:\n              schema:\n                type: object\n                additionalProperties: {}\n          description: \u0027\u0027\n  /api/v1/service-category:\n    get:\n      operationId: service_category_list\n      summary: Получение категорий услуг\n      parameters:\n      - name: page\n        required: false\n        in: query\n        description: A page number within the paginated result set.\n        schema:\n          type: integer\n      tags:\n      - service-category\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/PaginatedServiceCategoryList\u0027\n          description: \u0027\u0027\n    post:\n      operationId: service_category_create\n      summary: Создание категории услуги\n      tags:\n      - service-category\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/ServiceCategory\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/ServiceCategory\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/ServiceCategory\u0027\n        required: true\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027201\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/ServiceCategory\u0027\n          description: \u0027\u0027\n  /api/v1/service-category/{id}:\n    get:\n      operationId: service_category_retrieve\n      summary: Получение категории по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this service category.\n        required: true\n      tags:\n      - service-category\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/ServiceCategory\u0027\n          description: \u0027\u0027\n    patch:\n      operationId: service_category_partial_update\n      summary: Частичное обновление данных категории\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this service category.\n        required: true\n      tags:\n      - service-category\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedServiceCategory\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedServiceCategory\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/PatchedServiceCategory\u0027\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/ServiceCategory\u0027\n          description: \u0027\u0027\n    delete:\n      operationId: service_category_destroy\n      summary: Удаление категории по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this service category.\n        required: true\n      tags:\n      - service-category\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027204\u0027:\n          description: No response body\n  /api/v1/services:\n    get:\n      operationId: services_list\n      summary: Получение услуг\n      parameters:\n      - name: page\n        required: false\n        in: query\n        description: A page number within the paginated result set.\n        schema:\n          type: integer\n      tags:\n      - services\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/PaginatedServiceList\u0027\n          description: \u0027\u0027\n    post:\n      operationId: services_create\n      summary: Создание услуги\n      tags:\n      - services\n      requestBody:\n        content:\n          application/json:\n            schema:\n              $ref: \u0027#/components/schemas/Service\u0027\n          application/x-www-form-urlencoded:\n            schema:\n              $ref: \u0027#/components/schemas/Service\u0027\n          multipart/form-data:\n            schema:\n              $ref: \u0027#/components/schemas/Service\u0027\n        required: true\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027201\u0027:\n          content:\n            application/json:\n              schema:\n                $ref: \u0027#/components/schemas/Service\u0027\n          description: \u0027\u0027\n  /api/v1/services/{id}:\n    get:\n      operationId: services_retrieve\n      summary: Получение услуги по его ID\n      parameters:\n      - in: path\n        name: id\n        schema:\n          type: integer\n        description: A unique integer value identifying this service.\n        required: true\n      tags:\n      - services\n      security:\n      - jwtAuth: []\n      - {}\n      responses:\n        \u0027200\u0027:\n